{
  "name": "driftbox",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Driftbox v7 — a 2D sci-fi Sokoban-variant puzzle game rebuild.",
  "scripts": {
    "dev": "vite",
    "dev:server": "tsx watch server/index.ts",
    "verify": "tsx scripts/verify-levels.ts",
    "gen": "tsx scripts/gen.ts",
    "smoke:ui": "tsx scripts/smoke-ui.ts",
    "smoke:api": "tsx scripts/smoke-api.ts",
    "typecheck": "tsc --noEmit",
    "build": "vite build && npm run build:server",
    "build:server": "esbuild server/index.ts --bundle --platform=node --format=esm --target=node22 --packages=external --outfile=dist-server/index.js",
    "start": "node dist-server/index.js",
    "preview:full": "npm run build && npm run start"
  },
  "dependencies": {
    "@fastify/static": "^8.0.4",
    "fastify": "^5.2.1"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.3",
    "@types/node": "^22.10.5",
    "esbuild": "^0.24.2",
    "jsdom": "^25.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
  }
}
